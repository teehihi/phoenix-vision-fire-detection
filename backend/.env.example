# PhoenixVision Backend
PROJECT_NAME=PhoenixVision API
AI_SERVICE_URL=http://localhost:8100
ALERT_CONFIDENCE_THRESHOLD=0.65
CORS_ORIGINS=["http://localhost:5173"]

# Registration OTP
# Doi thanh chuoi bi mat dai, kho doan khi deploy.
OTP_SECRET=change_this_to_a_long_random_secret
OTP_EXPIRE_MINUTES=5

# SMTP email sender for OTP
# Gmail: bat 2FA, tao App Password, roi dien vao SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=PhoenixVision Support
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true

# Firestore persistence
# Firebase Console > Project settings > Service accounts > Generate new private key.
FIREBASE_PROJECT_ID=phoenixvision-2105
FIREBASE_STORAGE_BUCKET=phoenixvision-2105.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
# Khi deploy co the dung JSON tren mot dong thay cho file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Auto-delete alerts, detections, timeline, emergency events, and snapshots.
DATA_RETENTION_DAYS=30

# ESP32 IoT Device
# Option 1: mDNS, nếu máy chạy backend resolve được .local
ESP32_BASE_URL=http://phoenixvision.local
# Option 2: để trống và cấu hình BACKEND_REGISTER_URL trong firmware ESP32
# ESP32_BASE_URL=
ESP32_REQUEST_TIMEOUT_SECONDS=2.5
ESP32_HEALTH_INTERVAL_SECONDS=5
ESP32_OFFLINE_FAILURE_THRESHOLD=3
ESP32_CIRCUIT_FAILURE_THRESHOLD=4
ESP32_CIRCUIT_COOLDOWN_SECONDS=15

# Tự động kích hoạt bơm sau số giây không có người xác nhận (Acknowledge) sự cố
ESP32_AUTO_PUMP_DELAY_SECONDS=10

