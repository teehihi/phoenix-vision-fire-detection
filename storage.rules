rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/snapshots/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
